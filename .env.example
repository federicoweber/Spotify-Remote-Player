# Copy this file to `.env` and fill in your Spotify app's Client ID.
# Get one at https://developer.spotify.com/dashboard (create an app).

# Required: the Client ID of your Spotify app.
VITE_SPOTIFY_CLIENT_ID=

# Optional: the redirect URI registered on your Spotify app.
# Must match EXACTLY what you entered in the dashboard (incl. path / trailing slash).
# The dashboard requires HTTPS and the login flow rejects "localhost", so use
# HTTPS with the loopback IP literal 127.0.0.1.
# The app reads the OAuth `code` from any path, so a bare origin works fine.
VITE_SPOTIFY_REDIRECT_URI=https://127.0.0.1:5005
